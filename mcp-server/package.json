{
  "name": "the-council-mcp",
  "version": "0.1.0",
  "description": "Among Us-themed AI agent council for structured multi-perspective planning — MCP server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "the-council-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "sandbox-ui"
  ],
  "scripts": {
    "build": "tsc && npm run bundle-sandbox",
    "bundle-sandbox": "cp -r ../sandbox/out sandbox-ui",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "cursor",
    "claude",
    "planning",
    "among-us",
    "council"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rexheng/the-council"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/ws": "^8.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
